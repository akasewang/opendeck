DATABASE_URL=
NEXT_PUBLIC_APP_URL=https://opendeck.akasewang.me

# GitHub ingestion only. Used by scheduled imports and GitHub API reads.
GITHUB_TOKEN=
# Optional override for scheduled ingestion jobs. Falls back to GITHUB_TOKEN.
GH_INGEST_TOKEN=
# Protects cron-only endpoints. Use at least 32 random characters in production.
CRON_SECRET=
# Required for signing auth/session tokens.
AUTH_SECRET=
# Comma-separated access controls. Only AUTH_ADMIN_EMAILS or admin invites grant admin.
# Leave allowed emails/domains blank to allow normal sign-up.
AUTH_ADMIN_EMAILS=
AUTH_ALLOWED_EMAILS=
AUTH_ALLOWED_DOMAINS=
AUTH_INVITE_ONLY=false

# Real email delivery through Resend. Sign-in is passwordless (magic link), so these
# are required in production for login, verification, alerts and digests. In dev,
# leaving them blank returns the magic-link URL in the request response instead.
EMAIL_FROM=
RESEND_API_KEY=
